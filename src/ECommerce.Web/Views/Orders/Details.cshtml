@model ECommerce.Web.Models.Order
@{
  ViewData["Title"] = $"Order #{Model.Id}";
}

<h1>Order #@Model.Id</h1>

<div class="card">
  <div class="row">
    <span class="badge">@Model.Status</span>
    <span class="badge">Created: @Model.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
  </div>

  <h3 style="margin-top:10px;">Items</h3>
  <table class="table">
    <thead>
      <tr><th>Item</th><th>Unit</th><th>Qty</th><th>Total</th></tr>
    </thead>
    <tbody>
      @foreach (var it in Model.Items)
      {
        <tr>
          <td>@it.ProductName</td>
          <td>$@((it.UnitPriceCents/100.0).ToString("0.00"))</td>
          <td>@it.Quantity</td>
          <td>$@((it.LineTotalCents/100.0).ToString("0.00"))</td>
        </tr>
      }
    </tbody>
  </table>

  <h3 style="margin-top:10px;">Totals</h3>
  <div class="row"><span>Subtotal</span><strong>$@((Model.SubtotalCents/100.0).ToString("0.00"))</strong></div>
  <div class="row"><span>Tax</span><strong>$@((Model.TaxCents/100.0).ToString("0.00"))</strong></div>
  <div class="row"><span>Shipping</span><strong>$@((Model.ShippingCents/100.0).ToString("0.00"))</strong></div>
  <div class="row"><span>Discount</span><strong>-$@((Model.DiscountCents/100.0).ToString("0.00"))</strong></div>
  <div class="row" style="margin-top:6px;"><span>Total</span><strong>$@((Model.TotalCents/100.0).ToString("0.00"))</strong></div>

  <h3 style="margin-top:10px;">Payment</h3>
  @if (Model.Payment is null)
  {
    <p class="badge">No payment record.</p>
  }
  else
  {
    <p class="badge">@Model.Payment.Provider - @Model.Payment.Status - @Model.Payment.ProviderReference</p>
  }
</div>
