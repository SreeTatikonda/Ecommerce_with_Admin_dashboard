@model List<ECommerce.Web.Models.Order>
@{
  ViewData["Title"] = "My Orders";
}

<h1>My Orders</h1>

@if (Model.Count == 0)
{
  <div class="card">
    <p>No orders yet.</p>
    <a class="btn primary" href="/">Shop now</a>
  </div>
}
else
{
  <table class="table">
    <thead>
      <tr>
        <th>Order</th>
        <th>Date</th>
        <th>Status</th>
        <th>Total</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    @foreach (var o in Model)
    {
      <tr>
        <td>#@o.Id</td>
        <td>@o.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
        <td><span class="badge">@o.Status</span></td>
        <td>$@((o.TotalCents/100.0).ToString("0.00"))</td>
        <td><a class="btn" href="/orders/details/@o.Id">Details</a></td>
      </tr>
    }
    </tbody>
  </table>
}
